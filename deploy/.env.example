# Copy to /opt/hexmap/.env on the droplet and fill in. Never commit the real file.

# --- Rust API (read by the server + compose) ---
# Supabase SESSION-POOLER connection (Connect dialog -> "Session pooler", port 5432).
# Use the pooler, NOT the Direct endpoint: db.<ref>.supabase.co is IPv6-only and the
# Docker container has no IPv6, so Direct crash-loops with "Network is unreachable".
# Also NOT the transaction pooler (:6543) — the handlers need multi-statement
# transactions + prepared statements, which only session mode supports.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Used to fetch the JWKS for ES256 JWT verification (no JWT secret needed).
SUPABASE_URL=https://<project-ref>.supabase.co

# Same-origin now, so not load-bearing, but the server requires it to be set.
CORS_ALLOWED_ORIGIN=https://yourdomain.com

PORT=8080

# --- Caddy / deploy ---
# Apex (or sub) domain Caddy serves and Cloudflare points at. Used by the Caddyfile.
DOMAIN=yourdomain.com

# Server image published by CI to GHCR (owner must be lowercase). The droplet pulls this.
API_IMAGE=ghcr.io/<owner>/hexmap-server:latest

# --- Observability (Grafana Cloud) — only needed for the `alloy` collector ---
# From your Grafana Cloud stack: Prometheus remote-write + Loki push endpoints/creds.
# GC_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
# GC_PROM_USER=<prometheus instance id>
# GC_PROM_PASS=<grafana cloud api token>
# GC_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
# GC_LOKI_USER=<loki instance id>
# GC_LOKI_PASS=<grafana cloud api token>
#
# Traces: the Rust server exports OTLP spans to Alloy, which forwards them to Grafana
# Cloud Tempo via the OTLP gateway. Only set OTEL_EXPORTER_OTLP_ENDPOINT when the alloy
# (observability) profile is running, or the api logs connection errors.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
# GC_OTLP_URL=https://otlp-gateway-prod-XX.grafana.net/otlp
# GC_OTLP_USER=<otlp instance id>
# GC_OTLP_PASS=<grafana cloud api token with traces:write>
