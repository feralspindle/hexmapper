# Copy to /opt/hexmap/.env on the droplet and fill in. Never commit the real file.

# --- Rust API (read by the server + compose) ---
# Supabase SESSION-mode connection (port 5432), NOT the transaction pooler — the
# handlers run multi-statement transactions. Use the LITERAL '@' in the password
# (not %40): sqlx parses the right-most '@' as the userinfo delimiter.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<db-host>:5432/postgres

# Used to fetch the JWKS for ES256 JWT verification (no JWT secret needed).
SUPABASE_URL=https://<project-ref>.supabase.co

# Same-origin now, so not load-bearing, but the server requires it to be set.
CORS_ALLOWED_ORIGIN=https://yourdomain.com

PORT=8080

# --- Caddy / deploy ---
# Apex (or sub) domain Caddy serves and Cloudflare points at. Used by the Caddyfile.
DOMAIN=yourdomain.com

# Server image published by CI to GHCR (owner must be lowercase). The droplet pulls this.
API_IMAGE=ghcr.io/<owner>/hexmap-server:latest
