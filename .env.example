VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# "rust" uses the same-origin /api/realtime WebSocket. Leave as "supabase"
# until migrations through 20260620000043 and the Rust server are deployed.
VITE_REALTIME_TRANSPORT=supabase

# "staging" enables the bug report button in the topnav
VITE_APP_ENV=

# Rust event-sourcing API server
VITE_API_BASE_URL=http://localhost:8080/api

# Grafana Cloud Frontend Observability (Faro) collector URL. Blank = disabled. Set it
# (from your Grafana Cloud Frontend Observability app) to capture JS errors, web
# vitals, and sessions.
VITE_FARO_URL=

# Optional Playwright E2E target and seeded test accounts. E2E_BASE_URL is only
# needed when running against staging instead of local Vite.
E2E_BASE_URL=
E2E_GM_EMAIL=
E2E_GM_PASSWORD=
E2E_PLAYER1_EMAIL=
E2E_PLAYER1_PASSWORD=
E2E_PLAYER2_EMAIL=
E2E_PLAYER2_PASSWORD=
